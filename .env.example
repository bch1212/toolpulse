# =====================
# ToolPulse env (root .env.example)
# =====================
# This is a SAMPLE — copy to api/.env and frontend/.env.local for local dev.

# === API (Railway service) ===
ENVIRONMENT=production
PORT=8000
DATABASE_URL=postgresql+asyncpg://toolpulse:CHANGE_ME@HOST:5432/toolpulse
REDIS_URL=redis://HOST:6379/0

# Auth — Clerk (https://clerk.com)
CLERK_SECRET_KEY=sk_live_CHANGE_ME
CLERK_JWKS_URL=https://CHANGE_ME.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://CHANGE_ME.clerk.accounts.dev

# Billing — Stripe
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_INDIE=price_CHANGE_ME
STRIPE_PRICE_PRO=price_CHANGE_ME
STRIPE_PRICE_TEAM=price_CHANGE_ME

# Alerts
SENDGRID_API_KEY=SG.CHANGE_ME
ALERT_FROM_EMAIL=alerts@toolpulse.io
DISCORD_ALERT_WEBHOOK=https://discord.com/api/webhooks/CHANGE_ME
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/services/CHANGE_ME

# Public URLs
PUBLIC_APP_URL=https://toolpulse.io
PUBLIC_API_URL=https://api.toolpulse.io

# === Frontend (Vercel) ===
NEXT_PUBLIC_SITE_URL=https://toolpulse.io
NEXT_PUBLIC_API_URL=https://api.toolpulse.io
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME
CLERK_SECRET_KEY=sk_live_CHANGE_ME

# === Content engine ===
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
GITHUB_TOKEN=ghp_CHANGE_ME
GITHUB_REPO=toolpulse/toolpulse
GITHUB_BRANCH=main
