{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*).md",
      "headers": [{ "key": "Content-Type", "value": "text/markdown; charset=utf-8" }]
    }
  ],
  "redirects": [
    { "source": "/github", "destination": "https://github.com/toolpulse/toolpulse", "permanent": false },
    { "source": "/pypi", "destination": "https://pypi.org/project/toolpulse/", "permanent": false },
    { "source": "/npm", "destination": "https://www.npmjs.com/package/toolpulse", "permanent": false }
  ]
}
